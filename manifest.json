{
    "manifest_version": 3,
    "name": "Bad Clients Extension",
    "description": "Enables gig and proposal analysis directly on Upwork",
    "icons": {
        "128": "icon-128.png"
    },
    "action": {
        "default_icon": "public/icon-32.png",
        "default_popup": "src/pages/popup/index.html"
    },
    "permissions": ["activeTab", "cookies", "storage"],
    "host_permissions": [
        "https://*.upwork.com/*",
        "https://upwork.com/*",
        "http://localhost:3000/*",
        "https://staging-badclients.vercel.app/*",
        "https://www.badclients.app/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://*.upwork.com/*",
                "http://localhost:3000/*",
                "https://staging-badclients.vercel.app/*",
                "https://www.badclients.app/*"
            ],
            "js": ["src/pages/content/index.tsx"],
            "css": ["contentStyle.css"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["contentStyle.css", "icon-128.png", "icon-32.png"],
            "matches": []
        }
    ]
}
